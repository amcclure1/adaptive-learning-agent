# Python bytecode and caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.hypothesis/
.tox/
.nox/

# Virtual environments
.venv/
venv/
env/
ENV/

# Coverage and test output
.coverage
.coverage.*
coverage.xml
htmlcov/
junit.xml

# Build and packaging output
build/
dist/
*.egg-info/
*.whl

# Local environment and secrets
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
credentials.json
auth.json
*-tokens.json

# Learner and operational data
user-data/*
!user-data/.gitignore
runtime/
local-state/
*.sqlite
*.sqlite3
*.db
*.db-journal
*.db-wal
*.db-shm
*.sqlite-journal
*.sqlite-wal
*.sqlite-shm

# Hermes-, Codex-, and MCP-local state
.hermes/
.codex/
mcp-tokens/
mcp-config.local.*
hermes-config.local.*

# Generated indexes, pack builds, and exports
.indexes/
generated-indexes/
pack-build/
pack-dist/
exports/
*.ala-pack.zip
*.learner-export.zip

# Temporary files
*.tmp
*.temp
*.bak
*.swp
*~

# IDE and OS-local files
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.example.json
.DS_Store
Thumbs.db
Desktop.ini
