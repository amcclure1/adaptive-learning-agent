{"answer_uniqueness_state":{"approval":null,"status":"pending"},"artifact_id":"q-sap-org-04-resource-sharing","artifact_type":"question","author":{"identity":"openai-codex-sap-org-04-content-author","identity_type":"model","role":"lesson_question_author"},"blueprint_references":[{"blueprint_id":"aws-sap-c02-assessment-blueprint","canonical_digest":"3362d465a410c84d40250cd3b6dcfa5ac80cfc25d0b8d7b034b45327b8049d8d","version":"0.3A.1"}],"canonical_digest":"a636d677537dca26383c8ebcc10776a2e648854be9b7db69b522d9f765b1a6b8","content_review_state":{"approval":null,"status":"pending"},"created_at":"2026-07-19T21:30:00Z","keyed_option_ids":["a"],"learner_explanation":"Option A is best. For a type that supports OU principals with organization sharing enabled, RAM can target accounts in an OU while the platform account retains ownership. The RAM permission is a ceiling, and consumer identities still need applicable allows. Duplicating the resource violates the ownership and overhead requirements. A broad administrator role does not implement the scoped resource-share model. A shared Regional resource is consumed in the Region where it exists in the owner account.","modified_at":"2026-07-20T00:41:00Z","objective_references":{"primary":"SAP-ORG-04","supporting":["SAP-FND-01","SAP-FND-02","SAP-ORG-02"]},"option_rationales":[{"category":"key_support","claim_references":[{"artifact_id":"clm-b-ram-owner","artifact_type":"claim","canonical_digest":"6e4d2c4137533df10b7fe5f92ac266344fbbb4a9918781bd74b8b9454d7432b4","revision":1},{"artifact_id":"clm-b-ram-permission-ceiling","artifact_type":"claim","canonical_digest":"a2b93808d2a2d0c8085a6a3f5f562e2c12751732471ae32d3400164231c94c5e","revision":1},{"artifact_id":"clm-b-ram-principals","artifact_type":"claim","canonical_digest":"1932fbdba3837d6ae8f9e8e3660adc78c7af0e2dd78ce5d1973212b5dbc77980","revision":3},{"artifact_id":"clm-b-ram-regional","artifact_type":"claim","canonical_digest":"1ab0e879de5d9feb8aae5fca0afe866a1a5d1db4f838da47ef88fd7fe10edf12","revision":1}],"is_keyed":true,"option_id":"a","rationale":"It satisfies ownership, OU targeting, layered permission, Region, and overhead requirements.","requirement_ids":["req-owner","req-scope","req-access","req-overhead"]},{"category":"excessive_operational_burden","claim_references":[{"artifact_id":"clm-b-ram-owner","artifact_type":"claim","canonical_digest":"6e4d2c4137533df10b7fe5f92ac266344fbbb4a9918781bd74b8b9454d7432b4","revision":1},{"artifact_id":"clm-b-ram-principals","artifact_type":"claim","canonical_digest":"1932fbdba3837d6ae8f9e8e3660adc78c7af0e2dd78ce5d1973212b5dbc77980","revision":3}],"is_keyed":false,"option_id":"b","rationale":"Each copy would be a separately owned resource in an application account and would recreate the administration the scenario asks to avoid.","requirement_ids":["req-owner","req-overhead"]},{"category":"wrong_security_boundary","claim_references":[{"artifact_id":"clm-b-ram-permission-ceiling","artifact_type":"claim","canonical_digest":"a2b93808d2a2d0c8085a6a3f5f562e2c12751732471ae32d3400164231c94c5e","revision":1},{"artifact_id":"clm-b-ram-principals","artifact_type":"claim","canonical_digest":"1932fbdba3837d6ae8f9e8e3660adc78c7af0e2dd78ce5d1973212b5dbc77980","revision":3}],"is_keyed":false,"option_id":"c","rationale":"A broad administrator role is not the scoped RAM share and permission model required by the scenario.","requirement_ids":["req-scope","req-access"]},{"category":"unstated_assumption","claim_references":[{"artifact_id":"clm-b-ram-regional","artifact_type":"claim","canonical_digest":"1ab0e879de5d9feb8aae5fca0afe866a1a5d1db4f838da47ef88fd7fe10edf12","revision":1}],"is_keyed":false,"option_id":"d","rationale":"The option assumes global access that the approved Regional-resource behavior does not provide.","requirement_ids":["req-access"]}],"options":[{"option_id":"a","text":"Create an AWS RAM resource share for the supported resource, target the selected OU, choose the appropriate RAM permission, and grant consumer identities only the required operations."},{"option_id":"b","text":"Copy the resource into every application account and let each team own and administer its copy."},{"option_id":"c","text":"Grant a broad cross-account administrator role into the platform account instead of creating a resource share."},{"option_id":"d","text":"Create a RAM share for the supported resource, target the selected OU in one Region, and require consumers to access the Regional resource from any Region as though it were global."}],"originality_review_state":{"review":null,"status":"pending"},"question_id":"q-sap-org-04-resource-sharing","question_type":"single_response","required_selection_count":1,"requirement_option_matrix":[{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"fails"},{"option_id":"c","result":"satisfies"},{"option_id":"d","result":"satisfies"}],"requirement_id":"req-owner"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"fails"},{"option_id":"c","result":"fails"},{"option_id":"d","result":"satisfies"}],"requirement_id":"req-scope"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"fails"},{"option_id":"c","result":"fails"},{"option_id":"d","result":"fails"}],"requirement_id":"req-access"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"fails"},{"option_id":"c","result":"satisfies"},{"option_id":"d","result":"satisfies"}],"requirement_id":"req-overhead"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"not_applicable"},{"option_id":"c","result":"not_applicable"},{"option_id":"d","result":"satisfies"}],"requirement_id":"con-supported"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"not_applicable"},{"option_id":"c","result":"not_applicable"},{"option_id":"d","result":"satisfies"}],"requirement_id":"con-org"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"satisfies"},{"op