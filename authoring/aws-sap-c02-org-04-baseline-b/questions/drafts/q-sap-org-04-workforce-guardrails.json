{"answer_uniqueness_state":{"approval":null,"status":"pending"},"artifact_id":"q-sap-org-04-workforce-guardrails","artifact_type":"question","author":{"identity":"openai-codex-sap-org-04-content-author","identity_type":"model","role":"lesson_question_author"},"blueprint_references":[{"blueprint_id":"aws-sap-c02-assessment-blueprint","canonical_digest":"3362d465a410c84d40250cd3b6dcfa5ac80cfc25d0b8d7b034b45327b8049d8d","version":"0.3A.1"}],"canonical_digest":"d17fcf273a39c3724fab100573440ab36123945ba42e4a71dfb57bbce8ab3931","content_review_state":{"approval":null,"status":"pending"},"created_at":"2026-07-19T21:30:00Z","keyed_option_ids":["a","b"],"learner_explanation":"Select A and B. Identity Center account assignments provide reusable account access and temporary credentials; correctly scoped SCPs provide the organization-level maximum-permission boundary for IAM users and roles subject to SCPs in member accounts. An SCP does not grant access. Per-account IAM users do not meet the centralized temporary-credential design. Permission sets alone do not meet the stated organizational guardrail requirement when teams can administer other identity policies. SCPs do not constrain management-account IAM users or roles, and targeting only that account does not establish the required member-account boundary. Service-linked roles are not affected by SCPs.","modified_at":"2026-07-20T04:14:00Z","objective_references":{"primary":"SAP-ORG-04","supporting":["SAP-FND-01","SAP-FND-02","SAP-ORG-02"]},"option_rationales":[{"category":"key_access","claim_references":[{"artifact_id":"clm-b-identity-temp-creds","artifact_type":"claim","canonical_digest":"297594e00dcb34eb40767089fb60b49d3abc67f221591e7ba09b154f68ac9f3b","revision":1},{"artifact_id":"clm-b-permission-set-reuse","artifact_type":"claim","canonical_digest":"3be97b23015d984a9a8e6dac82c818a9ae5876f0a240197867f6f4f0101c40ca","revision":1},{"artifact_id":"clm-b-permission-set-role","artifact_type":"claim","canonical_digest":"a92270f7c4d421e0d3b97a7fa0ce76dbe9a6ba168457582349b6b89fc5feae83","revision":1}],"is_keyed":true,"option_id":"a","rationale":"This supplies the reusable assignment and temporary-credential path without claiming that an SCP grants access.","requirement_ids":["req-access","req-temp","req-separation"]},{"category":"key_guardrail","claim_references":[{"artifact_id":"clm-b-scp-ceiling","artifact_type":"claim","canonical_digest":"c21f8093737aa908795c80b970033e33e4f0cd14782b25f29764d4e43fb3e223","revision":2},{"artifact_id":"clm-b-scp-feature-mode","artifact_type":"claim","canonical_digest":"9df8cc18f1289225609773df53bf94fb4bd579b65460c6fa5aa355213fae49b2","revision":1},{"artifact_id":"clm-b-scp-parent-chain","artifact_type":"claim","canonical_digest":"eccf19b57ca535576a71a7af1a69b20656c54a0b5d09495c1609f4370287b441","revision":3}],"is_keyed":true,"option_id":"b","rationale":"This supplies the maximum-permission guardrail for affected member-account principals.","requirement_ids":["req-guardrail","req-separation"]},{"category":"excessive_operational_burden","claim_references":[{"artifact_id":"clm-b-identity-temp-creds","artifact_type":"claim","canonical_digest":"297594e00dcb34eb40767089fb60b49d3abc67f221591e7ba09b154f68ac9f3b","revision":1},{"artifact_id":"clm-b-permission-set-reuse","artifact_type":"claim","canonical_digest":"3be97b23015d984a9a8e6dac82c818a9ae5876f0a240197867f6f4f0101c40ca","revision":1}],"is_keyed":false,"option_id":"c","rationale":"Duplicated users and distributed keys do not use the approved reusable temporary-credential path.","requirement_ids":["req-access","req-temp"]},{"category":"right_service_wrong_purpose","claim_references":[{"artifact_id":"clm-b-ou-policy-target","artifact_type":"claim","canonical_digest":"079e74a58fe39b16084f8ff9bff68564c89655dff153e1535d7f06083f2bb359","revision":1},{"artifact_id":"clm-b-permission-set-role","artifact_type":"claim","canonical_digest":"a92270f7c4d421e0d3b97a7fa0ce76dbe9a6ba168457582349b6b89fc5feae83","revision":1}],"is_keyed":false,"option_id":"d","rationale":"OUs group accounts for organization-policy application; they do not assign workforce identities or grant account permissions.","requirement_ids":["req-access","req-temp","req-separation"]},{"category":"wrong_boundary","claim_references":[{"artifact_id":"clm-b-management-scp-gap","artifact_type":"claim","canonical_digest":"e3312344d277a0092d87441d6ee327c092d452e2ee76e4adf5d2a0d873fe29af","revision":1}],"is_keyed":false,"option_id":"e","rationale":"SCPs do not constrain management-account IAM users or roles, and this targeting does not create the stated member-account guardrail.","requirement_ids":["req-guardrail"]}],"options":[{"option_id":"a","text":"Assign workforce users and groups to reusable IAM Identity Center permission sets for the required member accounts."},{"option_id":"b","text":"Attach correctly scoped SCPs to the target OUs or member accounts to bound the prohibited actions."},{"option_id":"c","text":"Create matching IAM users in every member account and distribute their access keys to the workforce."},{"option_id":"d","text":"Assign workforce users to the target OUs and use those OU assignments as their account permission grants."},{"option_id":"e","text":"Attach the SCPs only to the Organizations management account so their limits flow to every member account."}],"originality_review_state":{"review":null,"status":"pending"},"question_id":"q-sap-org-04-workforce-guardrails","question_type":"multiple_response","required_selection_count":2,"requirement_option_matrix":[{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"not_applicable"},{"option_id":"c","result":"fails"},{"option_id":"d","result":"fails"},{"option_id":"e","result":"fails"}],"requirement_id":"req-access"},{"cells":[{"option_id":"a","result":"satisfies"},{"option_id":"b","result":"not_applicable"},{"option_id":"c","result":"fails"},{"option_id":"d","result":"fails"},{"option_id":"e","result":"fails"}],"requirement_id":"